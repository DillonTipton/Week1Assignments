from pyspark import SparkConf, SparkContext

conf = SparkConf().setMaster("local[*]").setAppName("DegreesOfSeparation")
sc = SparkContext(conf = conf).getOrCreate()
sc.setLogLevel("WARN")

startCharacterID = 5636
targetCharacterID = 5630

# Accumulator is an updatable shared variable
# It lives in driver, executors send updates to driver
hitCounter = sc.accumulator(0)

# Setup Breadth-First-Search graph
def convertToBFS(line):
    fields = line.split()
    heroID = int(fields[0])
    connections = []
    for connection in fields[1:]:
        connections.append(int(connection))
    
    color = "WHITE"
    distance = 9999

    # If the node is the start node, mark it as such
    if(heroID == startCharacterID):
        color = "GRAY"
        distance = 0
    
    return (heroID, (connections, distance, color))

# Read the file and convert to BFS graph
def createStartingRdd():
    inputFile = sc.textFile("./MarvelGraph.txt")
    return inputFile.map(convertToBFS)

iterationRdd = createStartingRdd()

def bfsMap(node):
    characterID = node[0]
    data = node[1]
    connections = data[0]
    distance = data[1]
    color = data[2]

    results = []

    if color == "GRAY":
        for connection in connections:
            newCharacterID = connection
            newDistance = distance + 1
            newColor = "GRAY"
            if(newCharacterID == targetCharacterID):
                hitCounter.add(1)
            newEntry = (newCharacterID, ([], newDistance, newColor))
            results.append(newEntry)
        color = "BLACK"
    
    results.append((characterID, (connections, distance, color)))
    return results

# reduceByKey
def bfsReduce(hero1, hero2):
    # Get hero data
    connections1 = hero1[0]
    connections2 = hero2[0]
    distance1 = hero1[1]
    distance2 = hero2[1]
    color1 = hero1[2]
    color2 = hero2[2]

    # Combine
    # (these values are placeholders)
    distance = 9999
    color = color1
    connections = []

    # Combine lists
    if len(connections1) > 0:
        connections.extend(connections1)
    if len(connections2) > 0:
        connections.extend(connections2)
    
    # Minimum distance
    if distance1 < distance:
        distance = distance1
    if distance2 < distance:
        distance = distance2
    
    # Darkest color
    if color1 == 'WHITE' and color2 != 'WHITE':
        color = color2
    if color1 == 'GRAY' and color2 == 'BLACK':
        color = color2
    if color2 == 'WHITE' and color1 != 'WHITE':
        color = color1
    if color2 == 'GRAY' and color1 == 'BLACK':
        color = color1

    return (connections, distance, color)

for iteration in range(0, 10):
    print(f"Running BFS iteration #{iteration + 1}")

    # Iteration rows look like this: (1, ([3, 4], 9999, White))
    # flatMap reduces it to this: (1, ([], 1, Gray))
    # We will end up with duplicates of white nodes and gray connections
    mapped = iterationRdd.flatMap(bfsMap)

    # Reduction to remove duplicates
    iterationRdd = mapped.reduceByKey(bfsReduce)

    # Since transformations are lazy, we have to run an action to actually resolve the accumulation
    print(f"Processing {mapped.count()} values.")

    if hitCounter.value > 0:
        print(f"Hit the target character! from {hitCounter.value} different direction(s)!")
        break

sc.stop()
